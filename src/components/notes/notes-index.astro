---
import NotesCards from "@/components/notes/notes-cards.astro";
import AppLayout from "@/components/shared/app-layout.astro";
import Section from "@/components/shared/section.astro";
import Seo from "@/components/shared/seo.astro";
import type { Lang } from "@/i18n/config";
import { getDictionary } from "@/i18n/dictionary";
import { getNotes } from "@/lib/notes";

interface Props {
	lang: Lang;
}

const { lang } = Astro.props;
const t = getDictionary(lang).notesPage;
const published = await getNotes(lang);
---

<AppLayout>
  <Seo slot="metadata" title={t.seoTitle} description={t.description} />

  <Section class="pt-12 pb-16 lg:pt-24">
    <h1
      class="text-4xl leading-none font-bold tracking-tight text-balance sm:text-5xl lg:text-7xl"
    >
      {t.title}
    </h1>
    <p class="max-w-2xl pt-6 pb-6 text-pretty text-muted-foreground lg:pt-8 lg:pb-12 lg:text-lg">
      {t.description}
    </p>

    <NotesCards notes={published} lang={lang} />
  </Section>
</AppLayout>
