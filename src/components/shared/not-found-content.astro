---
import { ArrowLeft } from "lucide-react";
import AppLayout from "@/components/shared/app-layout.astro";
import Link from "@/components/shared/link.astro";
import Seo from "@/components/shared/seo.astro";
import { DotPattern } from "@/components/ui/dot-pattern";
import type { Lang } from "@/i18n/config";
import { getDictionary } from "@/i18n/dictionary";
import { localizePath } from "@/i18n/utils";

interface Props {
	lang: Lang;
	seoTitle?: string;
	heading?: string;
	description?: string;
	noindex?: boolean;
}

const { lang, seoTitle, heading, description, noindex } = Astro.props;
const t = getDictionary(lang).notFound;
const nav = getDictionary(lang).nav;

const resolvedSeoTitle = seoTitle ?? t.seoTitle;
const resolvedHeading = heading ?? t.heading;
const resolvedDescription = description ?? t.description;

const homeHref = localizePath("/", lang);
const notesHref = localizePath("/notes", lang);
const nowHref = localizePath("/now", lang);
---

<AppLayout bareWrapper>
  <Seo
    slot="metadata"
    title={resolvedSeoTitle}
    description={resolvedDescription}
    noindex={noindex}
  />

  <div
    class="relative isolate flex min-h-screen items-center justify-center overflow-hidden px-6 py-16"
  >
    <div class="relative z-10 flex max-w-md flex-col items-center text-center">
      <p
        class="text-8xl leading-none font-bold tracking-tighter text-muted-foreground/30 sm:text-9xl"
      >
        404
      </p>
      <h1 class="pt-2 text-2xl font-bold tracking-tight sm:text-3xl">
        {resolvedHeading}
      </h1>
      <p class="pt-3 text-balance text-muted-foreground">
        {resolvedDescription}
      </p>

      <slot name="suggestion" />

      <div class="flex flex-col items-center gap-4 pt-8">
        <Link href={homeHref} class="gap-2">
          <ArrowLeft /> {t.backHome}
        </Link>
        <p class="text-sm text-muted-foreground">
          {t.orHeadTo}{" "}
          <a
            href={notesHref}
            class="font-medium text-foreground underline-offset-4 hover:underline"
            >{nav.notes}</a
          >
          <span aria-hidden="true"> · </span>
          <a
            href={nowHref}
            class="font-medium text-foreground underline-offset-4 hover:underline"
            >{nav.now}</a
          >
        </p>
      </div>
    </div>

    <DotPattern
      glow
      client:idle
      className="-z-10 mask-[radial-gradient(420px_circle_at_center,var(--background),transparent)]"
    />
  </div>
</AppLayout>
