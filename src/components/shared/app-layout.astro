---
import "@/styles/global.css";
import rubikFont from "@fontsource-variable/rubik/files/rubik-latin-ext-wght-normal.woff2?url";
import { Dock } from "./dock/dock";
import Footer from "./footer.astro";

interface Props {
  bareWrapper?: boolean;
}

const { bareWrapper = false } = Astro.props;

const pathname = Astro.url.pathname;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
      href={rubikFont}
    />
    <script is:inline>
      (() => {
        try {
          const theme = localStorage.getItem("theme") || "system";
          const dark =
            theme === "dark" ||
            (theme === "system" &&
              window.matchMedia("(prefers-color-scheme: dark)").matches);
          document.documentElement.classList.toggle("dark", dark);
        } catch {}
      })();
    </script>
    <slot name="metadata" />
  </head>

  <body>
    {!bareWrapper && <Dock client:only="react" pathname={pathname} />}
    <main id="main">
      <slot />
    </main>
    {!bareWrapper && <Footer />}
  </body>
</html>
