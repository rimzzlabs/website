---
import Archive from "@/components/home/archive.astro";
import Experience from "@/components/home/experience.astro";
import Hero from "@/components/home/hero.astro";
import Notes from "@/components/home/notes.astro";
import Skill from "@/components/home/skill.astro";
import AppLayout from "@/components/shared/app-layout.astro";
import Seo from "@/components/shared/seo.astro";

const title = "Rizki Citra, Software Engineer";
const description =
	"Software engineering lets me create impactful, innovative solutions that align with my values and improve lives. It's structured, rewarding, and always evolving—keeping things exciting and full of growth.";
---

<AppLayout>
  <Seo slot="metadata" {title} {description} />

  <Hero />
  <Experience />
  <Skill />
  <Notes />
  <Archive />
</AppLayout>
