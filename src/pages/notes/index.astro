---
import { getCollection } from "astro:content";
import NotesCards from "@/components/notes/notes-cards.astro";
import AppLayout from "@/components/shared/app-layout.astro";
import Section from "@/components/shared/section.astro";
import Seo from "@/components/shared/seo.astro";

const notes = await getCollection("notes");

const published = notes
	.filter((note) => (import.meta.env.PROD ? note.data.status === "published" : true))
	.sort((a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime());

const title = "Notes";
const description =
	"Notes on what I've learned and how I learned it as a frontend software engineer — problem-solving, technical deep-dives, and the occasional recipe.";
---

<AppLayout>
  <Seo slot="metadata" {title} {description} />

  <Section class="pt-12 pb-16 lg:pt-24">
    <h1
      class="text-4xl leading-none font-bold tracking-tight text-balance sm:text-5xl lg:text-7xl"
    >
      Notes
    </h1>
    <p class="max-w-2xl pt-6 pb-6 text-pretty text-muted-foreground lg:pt-8 lg:pb-12 lg:text-lg">
      {description}
    </p>

    <NotesCards notes={published} />
  </Section>
</AppLayout>
