---
import NoteArticle from "@/components/notes/note-article.astro";
import { getNotes } from "@/lib/notes";

export async function getStaticPaths() {
	const notes = await getNotes("en");
	return notes.map(({ slug, note, translated }) => ({
		params: { slug },
		props: { note, translated },
	}));
}

const { note, translated } = Astro.props;
---

<NoteArticle lang="en" note={note} translated={translated} />
